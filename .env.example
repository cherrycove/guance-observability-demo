# Copy to .env before running Docker Compose. Replace both change-me values.
MYSQL_PASSWORD=change-me-mysql
MYSQL_ROOT_PASSWORD=change-me-root
DEMO_PORT=8080

# Optional: connect the application containers to a DataKit reachable from Docker.
DATAKIT_HOST=host.docker.internal
# With compose.datakit.yaml, use the DataKit container name and its external network.
DATAKIT_DOCKER_NETWORK=datakit-demo-net
DD_TRACE_SAMPLE_RATE=1.0
DD_ENV=demo
DD_VERSION=local
PROJECT_TAG=mall-demo

# Select which platform DataKit reports to. This drives the UI label and default console URL;
# DataKit's own dataway_url must point to the same platform.
DATAKIT_PROVIDER=guance

# RUM is intentionally off until an application is created in Guance or TrueWatch.
RUM_ENABLED=false
RUM_APPLICATION_ID=
# Optional Trace deep link. A workspace ID is required before the UI emits links.
# Leave the URL empty to use the provider default:
# guance -> https://console.guance.com/; truewatch -> https://ap1-console.truewatch.com/
OBSERVABILITY_CONSOLE_URL=
OBSERVABILITY_WORKSPACE_ID=
